# Archivos de instaladores (se descargan durante el build)
installers/*.msi
installers/*.exe

# Archivos binarios grandes de Node
files-win-licencia-pro/node/node.exe

# Permitir archivos de configuración necesarios
!files-win-licencia-pro/.env
!files-win-licencia-pro/Iniciar-TallerOS.bat

# Ignorar carpeta node (se descarga durante instalación)
talleros-standalone/node/

# Node modules
node_modules/
npm-debug.log*

# Archivos de sistema
.DS_Store
Thumbs.db

# Archivos de IDE
.vscode/
.idea/
*.swp
*.swo

# Archivos con nombres reservados de Windows
nul
NUL
con
CON
prn
PRN
aux
AUX

# Archivos temporales
*.tmp
*.temp
