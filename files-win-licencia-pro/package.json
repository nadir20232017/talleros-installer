{
  "name": "talleros-licensed",
  "version": "2.0.0",
  "description": "TallerOS Licensed - Sistema de gestión de taller con licencias",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build-mac": "electron-builder --mac",
    "build-mac:intel": "electron-builder --mac --x64",
    "build-mac:arm": "electron-builder --mac --arm64",
    "build-win": "electron-builder --win",
    "dist": "electron-builder --mac --publish=never"
  },
  "build": {
    "appId": "com.igsm.talleros.licensed",
    "productName": "TallerOS Licensed",
    "copyright": "© 2024 iGSM",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "src/**/*",
      "backend/**/*",
      "frontend/**/*",
      "node/**/*",
      "node_modules/**/*",
      "package.json",
      "LEEME-INSTALACION-WINDOWS.txt",
      "LEEME-INSTALACION-MAC.txt"
    ],
    "asarUnpack": [
      "node/**/*",
      "backend/**/*",
      "src/activation.html",
      "src/loading.html"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!node_modules/.cache"]
      },
      {
        "from": "frontend",
        "to": "frontend"
      },
      {
        "from": "node",
        "to": "node"
      }
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.business",
      "minimumSystemVersion": "10.15.0",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "dmg": {
      "title": "TallerOS Licensed",
      "backgroundColor": "#080a0e",
      "window": {
        "width": 640,
        "height": 480
      },
      "contents": [
        {
          "x": 130,
          "y": 240
        },
        {
          "x": 410,
          "y": 240,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 320,
          "y": 380,
          "type": "file",
          "path": "LEEME-INSTALACION-MAC.txt"
        }
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": "x64"
        }
      ],
      "publisherName": "iGSM Servicio Tecnico",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TallerOS Licensed",
      "artifactName": "TallerOS-Licensed-v${version}-Windows-x64-Setup.${ext}",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "deleteAppDataOnUninstall": true,
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.0.1",
    "electron-updater": "^6.1.7"
  }
}