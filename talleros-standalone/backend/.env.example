# ═══════════════════════════════════════════════════════
#  TallerOS Backend — Configuracion de entorno
# ═══════════════════════════════════════════════════════

# ── SERVIDOR ──────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── BASE DE DATOS PostgreSQL ──────────────────────────
# Opcion 1: URL completa (Railway, Render, etc)
DATABASE_URL=postgresql://usuario:password@host:5432/talleros

# Opcion 2: Configuracion por variables
DB_HOST=localhost
DB_PORT=5432
DB_NAME=talleros
DB_USER=talleros_user
DB_PASSWORD=your_secure_password
DB_SSL=true

# ── JWT AUTENTICACION ─────────────────────────────────
JWT_SECRET=cambia_esto_por_una_cadena_larga_aleatoria_64_chars
JWT_EXPIRES_IN=8h

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# ── EMAIL (nodemailer) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=app_password
SMTP_FROM=TallerOS <tu@gmail.com>

# ── ARCHIVOS SUBIDOS ──────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
